# === Email notifications for new audit requests ===
# Gmail SMTP setup (free with a Google Account + App Password):
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Copy the 16-char password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Where audit notifications are sent (defaults to business@yangonmarketingmachine.com)
NOTIFICATION_EMAIL=business@yangonmarketingmachine.com

# === Admin password for viewing audit requests in the dashboard ===
# Change this from the default on production!
ADMIN_PASSWORD=YMM-d4sh-7x2k!sEcUrE
